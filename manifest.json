{
  "manifest_version": 3,
  "name": "DOM Modifier",
  "description": "Apply custom CSS rules to selected websites.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "options_page": "src/options/options.html",
  "action": {
    "default_title": "DOM Modifier",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/shared/urlMatcher.js",
        "src/shared/storage.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
